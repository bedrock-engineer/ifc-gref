{
  "name": "ifc-gref",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": {
    "name": "Jules Blom",
    "email": "jules.blom@bedrock.engineer",
    "url": "https://bedrock.engineer"
  },
  "funding": {
    "type": "organization",
    "url": "https://www.buildingsmart.nl/"
  },
  "imports": {
    "#modules/crs": {
      "types": "./src/modules/crs/index.ts",
      "default": "./src/modules/crs/index.ts"
    },
    "#modules/ifc/worker": {
      "types": "./src/modules/ifc/worker/index.ts",
      "default": "./src/modules/ifc/worker/index.ts"
    },
    "#modules/*": {
      "types": "./src/modules/*.ts",
      "default": "./src/modules/*"
    },
    "#lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*"
    },
    "#state/*": {
      "types": "./src/state/*.ts",
      "default": "./src/state/*"
    },
    "#components/*": {
      "types": "./src/components/*.ts",
      "default": "./src/components/*"
    },
    "#worker/*": {
      "types": "./src/worker/*.ts",
      "default": "./src/worker/*"
    }
  },
  "scripts": {
    "dev": "npm run build:crs && vite",
    "build": "npm run build:crs && tsc -b && vite build",
    "build:crs": "node scripts/build-crs-manifest.mjs",
    "verify:crs": "node scripts/verify-crs-overrides.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "knip": "knip"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "3d-tiles-renderer": "^0.4.24",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "d3-dsv": "^3.0.1",
    "d3-polygon": "^3.0.1",
    "d3-scale": "^4.0.2",
    "geotiff": "3.0.5",
    "maplibre-gl": "^5.24.0",
    "ml-levenberg-marquardt": "^5.0.1",
    "neverthrow": "^8.2.0",
    "proj4": "^2.20.8",
    "react": "^19.2.6",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.6",
    "three": "^0.183.2",
    "web-ifc": "^0.0.77",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.2",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-dsv": "^3.0.7",
    "@types/d3-polygon": "^3.0.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/proj4": "^2.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "epsg-index": "^2.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "knip": "^6.4.1",
    "react-scan": "^0.5.6",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8"
  }
}
